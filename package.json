{
  "name": "agento",
  "version": "0.1.0",
  "description": "AI operability scoring for repositories",
  "type": "module",
  "bin": {
    "agento": "./dist/cli/index.js"
  },
  "main": "./dist/cli/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/cli/index.ts",
    "health": "tsx src/cli/index.ts",
